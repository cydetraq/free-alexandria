{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Free Alexandria build lockfile",
  "type": "object",
  "required": ["format_version", "profile", "catalog_revision", "generated_at", "records"],
  "properties": {
    "format_version": {"const": 1},
    "profile": {"type": "object"},
    "catalog_revision": {"type": "string"},
    "generated_at": {"type": "string", "format": "date-time"},
    "records": {"type": "array"}
  }
}
