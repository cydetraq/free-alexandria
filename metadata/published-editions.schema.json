{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Free Alexandria published-edition registry",
  "type": "object",
  "required": ["format_version", "editions"],
  "properties": {
    "format_version": {"const": 1},
    "editions": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["edition_id", "language", "source_id", "source_item_id", "files"],
          "properties": {
            "edition_id": {"type": "string"},
            "language": {"type": "string"},
            "source_id": {"type": "string"},
            "source_item_id": {"type": "string"},
            "files": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["role", "path", "sha256", "bytes"],
                "properties": {
                  "role": {"type": "string"},
                  "path": {"type": "string"},
                  "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
                  "bytes": {"type": "integer", "minimum": 1}
                }
              }
            }
          }
        }
      }
    }
  }
}
